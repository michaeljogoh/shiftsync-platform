##############################################
# ShiftSync API (.env)
# Copy this file to `.env` and fill values.
##############################################

NODE_ENV=development
PORT=3000

# Required (CORS + links in emails / UI)
FRONTEND_URL=http://localhost:5173

# Required (PostgreSQL)
# Example local DB URL (edit user/pass/db as needed)
DATABASE_URL=postgresql://user:pass@localhost:5432/shiftsync

# Required (JWT)
# Must be >= 16 chars
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=15m

# Required (refresh tokens)
# Must be >= 16 chars
REFRESH_TOKEN_SECRET=change-me-to-another-long-random-secret
REFRESH_TOKEN_EXPIRES_IN=7d

# Email (optional). If empty, email sending is disabled even if ENABLE_EMAIL_NOTIFICATIONS=true.
POSTMARK_SERVER_TOKEN=
POSTMARK_FROM_EMAIL=noreply@shiftsync.app
ENABLE_EMAIL_NOTIFICATIONS=true

# Redis (optional) - only needed if you wire Redis-backed features later
REDIS_URL=

# Scheduling / policy knobs
OVERTIME_HARD_BLOCK_HOURS=12
DEFAULT_EDIT_CUTOFF_HOURS=48

# Shift publishing policy: warn by default; set to true to block publish when headcount not filled
PUBLISH_BLOCK_UNFILLED_HEADCOUNT=false
